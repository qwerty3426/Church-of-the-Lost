  posText: {fileID: 640335571}
  neuText: {fileID: 1335235439}
  negText: {fileID: 392454222}
  finalSentences: []
  priestIntroSentences:
  - "\u0427\u0430\u0441 \u0441\u043F\u043B\u0438\u0432\u0430\u0454?"
  neutralEnding1: {fileID: 2800000, guid: 5d481990e444cb545af5e3e8235a80e6, type: 3}
  neutralEnding2: {fileID: 2800000, guid: bdb7a8b3fe8465c44b88e93e8e928f6e, type: 3}
  neutralEnding3: {fileID: 2800000, guid: 565543a758ee5b04bb3782c0f93ad079, type: 3}
  neutralEnding4: {fileID: 2800000, guid: 50f3f077033e7e64da25685a2892e9f8, type: 3}
  neutralEndingText1:
  - "\u042F \u0440\u0456\u0437\u043A\u043E \u043F\u0440\u043E\u043A\u0438\u043D\u0443\u0432\u0441\u044F."
  - "\u0423 \u043A\u0456\u043C\u043D\u0430\u0442\u0456 \u0431\u0443\u043B\u043E \u0442\u0438\u0445\u043E."
  - "\u0421\u043E\u043D \u0437\u0434\u0430\u0432\u0430\u0432\u0441\u044F \u043D\u0430\u0434\u0442\u043E
    \u0440\u0435\u0430\u043B\u044C\u043D\u0438\u043C."
  neutralEndingText2:
  - "\u041C\u0438\u043D\u0443\u043B\u043E \u043A\u0456\u043B\u044C\u043A\u0430 \u0434\u043D\u0456\u0432.\n"
  - "\u042F \u0432\u0456\u0434\u043C\u043E\u0432\u0438\u0432\u0441\u044F \u0432\u0456\u0434
    \u0441\u0432\u043E\u0433\u043E \u043F\u0435\u0440\u0448\u043E\u0433\u043E \u0441\u043B\u0443\u0436\u0456\u043D\u043D\u044F
    \u0432 \u0426\u0435\u0440\u043A\u0432\u0456 \u0417\u0430\u0433\u0443\u0431\u043B\u0435\u043D\u0438\u0445.\n"
  - "\u0410\u043B\u0435 \u0441\u043F\u043E\u0433\u0430\u0434\u0438 \u043D\u0435 \u0437\u043D\u0438\u043A\u0430\u043B\u0438.\n\n"
  - "\u0422\u043E\u043C\u0443 \u044F \u043F\u043E\u0447\u0430\u0432 \u0448\u0443\u043A\u0430\u0442\u0438
    \u0432\u0456\u0434\u043F\u043E\u0432\u0456\u0434\u0456 \u0441\u0430\u043C.\n"
  neutralEndingText3:
  - "\u0421\u0435\u0440\u0435\u0434 \u0441\u0442\u0430\u0440\u0438\u0445 \u0430\u0440\u0445\u0456\u0432\u0456\u0432
    \u044F \u0437\u043D\u0430\u0439\u0448\u043E\u0432 \u043E\u0434\u043D\u0443 \u0441\u0442\u0430\u0442\u0442\u044E.\r\n"
  - " \u0406 \u0442\u043E\u0434\u0456 \u0437\u0440\u043E\u0437\u0443\u043C\u0456\u0432...\r\n\r\n"
  - "\u0423\u0441\u0435, \u0449\u043E \u044F \u0431\u0430\u0447\u0438\u0432 \u0443\u0432\u0456
    \u0441\u043D\u0456, \u0431\u0443\u043B\u043E \u043F\u0440\u0430\u0432\u0434\u043E\u044E.\r\n\r\n"
  neutralEndingText4:
  - "\u042F \u0432\u0440\u044F\u0442\u0443\u0432\u0430\u0432\u0441\u044F?"
  badEnding1: {fileID: 2800000, guid: 5b45423f7d4536b4cb8733379376baba, type: 3}
  badEnding2: {fileID: 2800000, guid: 328011798f4310b49ba586a309d3d01f, type: 3}
  badEndingText1:
  - "\u042F \u0431\u0456\u043B\u044C\u0448\u0435 \u043D\u0435 \u043F\u0430\u043C'\u044F\u0442\u0430\u044E,
    \u0441\u043A\u0456\u043B\u044C\u043A\u0438 \u0447\u0430\u0441\u0443 \u043F\u0440\u043E\u0432\u0456\u0432
    \u0443 \u0446\u0438\u0445 \u0431\u0456\u043B\u0438\u0445 \u0441\u0442\u0456\u043D\u0430\u0445."
  - "\u041B\u0456\u043A\u0430\u0440\u0456 \u043A\u0430\u0437\u0430\u043B\u0438, \u0449\u043E
    \u0432\u0441\u0435 \u043F\u043E\u0447\u0430\u043B\u043E\u0441\u044F \u0431\u0430\u0433\u0430\u0442\u043E
    \u0440\u043E\u043A\u0456\u0432 \u0442\u043E\u043C\u0443.\n"
  - "\u0422\u0456\u0454\u0457 \u043D\u043E\u0447\u0456 \u0432 \u0426\u0435\u0440\u043A\u0432\u0456
    \u0417\u0430\u0433\u0443\u0431\u043B\u0435\u043D\u0438\u0445 \u0441\u0442\u0430\u043B\u043E\u0441\u044F
    \u0432\u0431\u0438\u0432\u0441\u0442\u0432\u043E.\n"
  - "\u0421\u0435\u0441\u0442\u0440\u0430 \u0410\u043D\u043D\u0430 \u043D\u0435 \u0431\u0443\u043B\u0430
    \u0436\u0435\u0440\u0442\u0432\u043E\u044E. \u0412\u043E\u043D\u0430 \u0441\u0442\u0430\u043B\u0430
    \u0441\u0432\u0456\u0434\u043A\u043E\u043C.\n\n\n"
  - "\u0412\u043E\u043D\u0430 \u0431\u0430\u0447\u0438\u043B\u0430 \u0442\u0435,
    \u0449\u043E \u043D\u0435 \u043F\u043E\u0432\u0438\u043D\u043D\u0430 \u0431\u0443\u043B\u0430
    \u0431\u0430\u0447\u0438\u0442\u0438.\n\n"
  - "\u0421\u0432\u044F\u0449\u0435\u043D\u0438\u043A \u0434\u0430\u0432\u043D\u043E
    \u043F\u0435\u0440\u0435\u0442\u0432\u043E\u0440\u0438\u0432 \u0446\u0435\u0440\u043A\u0432\u0443
    \u043D\u0430 \u043C\u0456\u0441\u0446\u0435 \u0433\u0440\u0456\u0445\u0430. \n"
  - "\u0419\u043E\u043C\u0443 \u0434\u043E\u043F\u043E\u043C\u0430\u0433\u0430\u043B\u0430
    \u0436\u0456\u043D\u043A\u0430, \u044F\u043A\u0443 \u0432\u0441\u0456 \u0432\u0432\u0430\u0436\u0430\u043B\u0438
    \u0437\u0432\u0438\u0447\u0430\u0439\u043D\u043E\u044E \u043F\u0440\u0438\u0445\u043E\u0436\u0430\u043D\u043A\u043E\u044E.\n"
  - "\u041D\u0430\u0441\u043F\u0440\u0430\u0432\u0434\u0456 \u0436 \u0432\u043E\u043D\u0430
    \u0431\u0443\u043B\u0430 \u0439\u043E\u0433\u043E \u043C\u0430\u0442\u0456\u0440'\u044E.\u0420\u0430\u0437\u043E\u043C
    \u0432\u043E\u043D\u0438 \u043F\u0440\u0438\u0445\u043E\u0432\u0443\u0432\u0430\u043B\u0438
    \u0441\u0432\u043E\u0457 \u0437\u043B\u043E\u0447\u0438\u043D\u0438 \u0440\u043E\u043A\u0430\u043C\u0438.\n"
  - "\u0422\u0456\u0454\u0457 \u043D\u043E\u0447\u0456 \u0410\u043D\u043D\u0430 \u0434\u0456\u0437\u043D\u0430\u043B\u0430\u0441\u044F
    \u043F\u0440\u0430\u0432\u0434\u0443.\n"
  - "\u0410 \u043F\u043E\u0442\u0456\u043C \u0437\u043D\u0438\u043A\u043B\u0430."
  - "\u0404\u0434\u0438\u043D\u0438\u043C \u0441\u0432\u0456\u0434\u043A\u043E\u043C
    \u0442\u043E\u0433\u043E, \u0449\u043E \u0441\u0442\u0430\u043B\u043E\u0441\u044F,
    \u0431\u0443\u0432 \u043C\u043E\u043B\u043E\u0434\u0438\u0439 \u0447\u043E\u043B\u043E\u0432\u0456\u043A
    \u043D\u0430 \u0456\u043C'\u044F \u0410\u043D\u0434\u0440\u0456\u0439."
  - "\u0412\u0456\u043D \u0431\u0430\u0447\u0438\u0432 \u0443\u0441\u0435...\u0411\u0430\u0447\u0438\u0432
    \u043A\u0440\u043E\u0432...\u0411\u0430\u0447\u0438\u0432 \u0441\u0442\u0440\u0430\u0445."
  - "\u0411\u0430\u0447\u0438\u0432, \u044F\u043A \u043F\u0440\u0430\u0432\u0434\u0430
    \u0437\u043D\u0438\u043A\u0430\u0454 \u0440\u0430\u0437\u043E\u043C \u0456\u0437
    \u0442\u0438\u043C\u0438, \u0445\u0442\u043E \u043D\u0430\u043C\u0430\u0433\u0430\u0432\u0441\u044F
    \u0457\u0457 \u0432\u0456\u0434\u043A\u0440\u0438\u0442\u0438."
  - "\u041F\u0456\u0441\u043B\u044F \u0442\u0456\u0454\u0457 \u043D\u043E\u0447\u0456
    \u0410\u043D\u0434\u0440\u0456\u0439 \u0431\u0456\u043B\u044C\u0448\u0435 \u043D\u0456\u043A\u043E\u043B\u0438
    \u043D\u0435 \u0431\u0443\u0432 \u043A\u043E\u043B\u0438\u0448\u043D\u0456\u043C.\n"
  - "\u0421\u043F\u043E\u0433\u0430\u0434\u0438 \u043F\u0435\u0440\u0435\u0441\u043B\u0456\u0434\u0443\u0432\u0430\u043B\u0438
    \u0439\u043E\u0433\u043E \u0440\u043E\u043A\u0430\u043C\u0438.\n"
  - "\u0412\u043E\u043D\u0438 \u043F\u043E\u0432\u0435\u0440\u0442\u0430\u043B\u0438\u0441\u044F
    \u0437\u043D\u043E\u0432\u0443 \u0456 \u0437\u043D\u043E\u0432\u0443, \u043F\u043E\u043A\u0438
    \u0440\u0435\u0430\u043B\u044C\u043D\u0456\u0441\u0442\u044C \u043D\u0435 \u043F\u043E\u0447\u0430\u043B\u0430
    \u0437\u043C\u0456\u0448\u0443\u0432\u0430\u0442\u0438\u0441\u044F \u0437 \u043C\u0430\u0440\u0435\u043D\u043D\u044F\u043C.\n"
  badEndingText2:
  - "\u0406 \u043B\u0438\u0448\u0435 \u0442\u0435\u043F\u0435\u0440 \u044F \u0437\u0440\u043E\u0437\u0443\u043C\u0456\u0432
    \u0442\u0435, \u0447\u043E\u0433\u043E \u043D\u0435 \u043C\u0456\u0433 \u0437\u0440\u043E\u0437\u0443\u043C\u0456\u0442\u0438
    \u0440\u0430\u043D\u0456\u0448\u0435.\n"
  - "\u041D\u0435 \u0456\u0441\u043D\u0443\u0432\u0430\u043B\u043E \u0436\u043E\u0434\u043D\u043E\u0433\u043E
    \u0433\u043E\u043B\u043E\u0432\u043D\u043E\u0433\u043E \u0433\u0435\u0440\u043E\u044F."
  - "\u041D\u0435 \u0456\u0441\u043D\u0443\u0432\u0430\u043B\u043E \u0432\u0456\u0434\u0432\u0456\u0434\u0443\u0432\u0430\u0447\u0456\u0432
    \u0446\u0435\u0440\u043A\u0432\u0438.\n\n"
  - "\u041D\u0435 \u0456\u0441\u043D\u0443\u0432\u0430\u043B\u043E \u0446\u0438\u0445
    \u0440\u043E\u0437\u043C\u043E\u0432."
  - "\u0416\u0456\u043D\u043A\u0430.\n\n"
  - "\u0421\u0432\u044F\u0449\u0435\u043D\u0438\u043A\u0430.\n"
  - "\u0421\u0435\u0441\u0442\u0440\u0430 \u0410\u043D\u043D\u0430.."
  - "\u0423\u0441\u0456 \u0432\u043E\u043D\u0438 \u0431\u0443\u043B\u0438 \u043B\u0438\u0448\u0435
    \u0443\u043B\u0430\u043C\u043A\u0430\u043C\u0438 \u043C\u043E\u0454\u0457 \u043F\u0430\u043C'\u044F\u0442\u0456."
  - "\u042F \u0432\u0435\u0441\u044C \u0446\u0435\u0439 \u0447\u0430\u0441 \u0440\u043E\u0437\u043C\u043E\u0432\u043B\u044F\u0432
    \u0441\u0430\u043C \u0456\u0437 \u0441\u043E\u0431\u043E\u044E."
  - "\u0411\u043E \u044F \u0456 \u0454 \u0410\u043D\u0434\u0440\u0456\u0439."
  - "\u041E\u0441\u0442\u0430\u043D\u043D\u0456\u0439 \u0441\u0432\u0456\u0434\u043E\u043A
    \u0442\u0456\u0454\u0457 \u043D\u043E\u0447\u0456."
  - "\u0406, \u043C\u043E\u0436\u043B\u0438\u0432\u043E, \u0457\u0457 \u043E\u0441\u0442\u0430\u043D\u043D\u044F
    \u0436\u0435\u0440\u0442\u0432\u0430."
  - "\u041B\u0456\u043A\u0430\u0440\u0456 \u043D\u0430\u0437\u0438\u0432\u0430\u044E\u0442\u044C
    \u0446\u0435 \u0431\u043E\u0436\u0435\u0432\u0456\u043B\u043B\u044F\u043C."
  - "\u042F \u043D\u0430\u0437\u0438\u0432\u0430\u044E \u0446\u0435 \u043F\u0440\u0430\u0432\u0434\u043E\u044E."
  - "\u041F\u0440\u0430\u0432\u0434\u043E\u044E, \u044F\u043A\u0443 \u043D\u0456\u0445\u0442\u043E
    \u0431\u0456\u043B\u044C\u0448\u0435 \u043D\u0435 \u0445\u043E\u0447\u0435 \u043F\u0430\u043C'\u044F\u0442\u0430\u0442\u0438."
  goodEnding1: {fileID: 2800000, guid: a011d8f2ce1f5944b97cc4fbc2a435a4, type: 3}
  goodEnding2: {fileID: 2800000, guid: a7e0dc407b14f1641be6658824d64855, type: 3}
  goodEndingText1:
  - "\u041C\u0438\u043D\u0443\u043B\u043E \u0431\u0430\u0433\u0430\u0442\u043E \u0440\u043E\u043A\u0456\u0432."
  - "\u041F\u0440\u0430\u0432\u0434\u0430 \u043D\u0430\u0440\u0435\u0448\u0442\u0456
    \u0441\u0442\u0430\u043B\u0430 \u0432\u0456\u0434\u043E\u043C\u043E\u044E \u0432\u0441\u0456\u043C."
  - "\u0422\u0435, \u0449\u043E \u043A\u043E\u043B\u0438\u0441\u044C \u0431\u0443\u043B\u043E
    \u043C\u0456\u0441\u0446\u0435\u043C \u0441\u0442\u0440\u0430\u0445\u0443, \u0431\u0456\u043B\u044C\u0448\u0435
    \u043D\u0438\u043C \u043D\u0435 \u0431\u0443\u043B\u043E."
  - "\u0411\u0456\u043B\u044F \u0441\u0442\u0430\u0440\u043E\u0457 \u0446\u0435\u0440\u043A\u0432\u0438
    \u0432\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B\u0438 \u043F\u0430\u043C'\u044F\u0442\u043D\u0438\u0439
    \u043A\u0430\u043C\u0456\u043D\u044C \u043D\u0430 \u0447\u0435\u0441\u0442\u044C
    \u0441\u0435\u0441\u0442\u0440\u0438 \u0410\u043D\u043D\u0438 \u0442\u0430 \u0432\u0441\u0456\u0445,
    \u0445\u0442\u043E \u043F\u043E\u0441\u0442\u0440\u0430\u0436\u0434\u0430\u0432
    \u0447\u0435\u0440\u0435\u0437 \u0442\u0456 \u043F\u043E\u0434\u0456\u0457."
  - "\u041B\u044E\u0434\u0438 \u0431\u0456\u043B\u044C\u0448\u0435 \u043D\u0435 \u043E\u043C\u0438\u043D\u0430\u043B\u0438
    \u0446\u0435 \u043C\u0456\u0441\u0446\u0435."
  - "\u0412\u043E\u043D\u0438 \u043F\u0440\u0438\u043D\u043E\u0441\u0438\u043B\u0438
    \u043A\u0432\u0456\u0442\u0438."
  - "\u0417\u0430\u043F\u0430\u043B\u044E\u0432\u0430\u043B\u0438 \u0441\u0432\u0456\u0447\u043A\u0438."
  - "\u0417\u0443\u043F\u0438\u043D\u044F\u043B\u0438\u0441\u044F \u043D\u0430 \u043C\u0438\u0442\u044C,
    \u0449\u043E\u0431 \u0437\u0433\u0430\u0434\u0430\u0442\u0438 \u0442\u0438\u0445,
    \u0447\u0438\u0439 \u0433\u043E\u043B\u043E\u0441 \u043A\u043E\u043B\u0438\u0441\u044C
    \u043D\u0430\u043C\u0430\u0433\u0430\u043B\u0438\u0441\u044F \u0437\u043C\u0443\u0441\u0438\u0442\u0438
    \u0437\u0430\u043C\u043E\u0432\u043A\u043D\u0443\u0442\u0438."
  - "\u0406 \u0432\u043F\u0435\u0440\u0448\u0435 \u0437\u0430 \u0434\u043E\u0432\u0433\u0438\u0439
    \u0447\u0430\u0441 \u043D\u0430\u0434 \u0446\u0435\u0440\u043A\u0432\u043E\u044E
    \u043F\u0430\u043D\u0443\u0432\u0430\u0432 \u043D\u0435 \u0441\u0442\u0440\u0430\u0445."
  - "\u0410 \u0441\u043F\u043E\u043A\u0456\u0439."
  goodEndingText2:
  - "\u0412\u0438 \u0437\u0440\u043E\u0431\u0438\u043B\u0438 \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u0438\u0439
    \u0432\u0438\u0431\u0456\u0440.\n"
  - "\u041F\u0440\u0430\u0432\u0434\u0430 \u0431\u0443\u043B\u0430 \u043F\u043E\u0447\u0443\u0442\u0430.\n"
  - "\u041F\u0430\u043C'\u044F\u0442\u044C \u0437\u0430\u043B\u0438\u0448\u0438\u043B\u0430\u0441\u044F."
  typingSpeed: 0.07
  fadeSpeed: 1
