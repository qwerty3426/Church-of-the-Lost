  introSentences:
  - "\u043B\u043E\u0445"
  churchTexture: {fileID: 2800000, guid: d4859122fc2e0e044be2f4d68bb5117c, type: 3}
  finalTexture: {fileID: 2800000, guid: d4859122fc2e0e044be2f4d68bb5117c, type: 3}
