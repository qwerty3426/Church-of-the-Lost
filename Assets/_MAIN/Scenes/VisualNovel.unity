  textDisplay: {fileID: 887826988}
  backgroundDisplay: {fileID: 1084579251}
  fadeScreenGroup: {fileID: 501948443}
  dialoguePanel: {fileID: 0}
  sceneButton: {fileID: 0}
  endingButton: {fileID: 0}
  audioSource: {fileID: 1210481014}
  bellSound: {fileID: 8300000, guid: f30d338b16e36154c8532eb5272e6b9a, type: 3}
  introSentences:
  - "\u041B\u0435\u0434\u044C \u0447\u0443\u0442\u043D\u043E \u2014 \u0432\u0456\u0442\u0435\u0440...
    \u0456 \u0434\u0430\u043B\u0435\u043A\u0438\u0439 \u0434\u0437\u0432\u0456\u043D
    \u0434\u0437\u0432\u043E\u043D\u0443."
  churchTexture: {fileID: 2800000, guid: 9f66e75ac3c5be541aae51916528170b, type: 3}
  churchSentences:
  - "\u0423 \u043A\u043E\u0436\u043D\u043E\u043C\u0443 \u043C\u0456\u0441\u0446\u0456
    \u0454 \u0456\u0441\u0442\u043E\u0440\u0456\u044F."
  - "\u0410\u043B\u0435 \u043D\u0435 \u043A\u043E\u0436\u043D\u0430 \u0456\u0441\u0442\u043E\u0440\u0456\u044F
    \u0445\u043E\u0447\u0435, \u0449\u043E\u0431 \u0457\u0457 \u043F\u043E\u0447\u0443\u043B\u0438."
  - "\u0426\u044F \u0446\u0435\u0440\u043A\u0432\u0430... \u043F\u0430\u043C'\u044F\u0442\u0430\u0454."
  doorSound: {fileID: 8300000, guid: 8d72b9df77ba4f741a91d4a7f4b150dd, type: 3}
  darkSentences:
  - "\u041C\u0435\u043D\u0435 \u043D\u0430\u043F\u0440\u0430\u0432\u0438\u043B\u0438
    \u0441\u044E\u0434\u0438..."
  roomTexture: {fileID: 2800000, guid: 4b15090fab074e74f932d890be3788ce, type: 3}
  roomSentences:
  - "\u0421\u043A\u0430\u0437\u0430\u043B\u0438, \u0449\u043E \u0446\u0435 \u043C\u043E\u0454
    \u043F\u0435\u0440\u0448\u0435 \u0441\u043B\u0443\u0436\u0456\u043D\u043D\u044F."
  - "\u0414\u0438\u0432\u043D\u043E..."
  - "\u041D\u0456\u0445\u0442\u043E \u043D\u0435 \u0445\u043E\u0442\u0456\u0432 \u043D\u0430\u0432\u0456\u0442\u044C
    \u0433\u043E\u0432\u043E\u0440\u0438\u0442\u0438 \u043F\u0440\u043E \u0446\u0435
    \u043C\u0456\u0441\u0446\u0435."
  - "\u0410\u043B\u0435 \u044F\u043A\u0449\u043E \u0411\u043E\u0433 \u043F\u0440\u0438\u0432\u0456\u0432
    \u043C\u0435\u043D\u0435 \u0441\u044E\u0434\u0438..."
  forestSound: {fileID: 8300000, guid: 5f4e61891df15b54c95608d518dadfa0, type: 3}
  darkSentences2:
  - "\u0417\u043D\u0430\u0447\u0438\u0442\u044C \u044F \u043C\u0430\u044E \u0437\u0430\u043B\u0438\u0448\u0438\u0442\u0438\u0441\u044C?"
  - '?'
  - '?'
  - "\u0417\u0430\u043B\u0438\u0448\u0438\u0442\u0438\u0441\u044F...?"
  chapelTexture: {fileID: 2800000, guid: d4859122fc2e0e044be2f4d68bb5117c, type: 3}
  chapelSentences:
  - "\u0414\u043E\u0441\u0438\u0442\u044C,\u0447\u0430\u0441 \u0440\u043E\u0437\u043F\u043E\u0447\u0430\u0442\u0438
